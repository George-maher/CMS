APP_NAME=ChurchManager
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app.onrender.com
FRONTEND_URL=https://your-frontend.vercel.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ──────────────────────────────────────────────
# Database (Supabase PostgreSQL)
# Use Supabase connection pooler URL for production:
# DATABASE_URL=postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# ──────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=church_management
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=require
# DATABASE_URL=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

# Use 'file' for basic setups, 'redis' for production
CACHE_STORE=file

# ──────────────────────────────────────────────
# Mail / Resend
# ──────────────────────────────────────────────
MAIL_MAILER=resend
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@churchmanager.app"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# ──────────────────────────────────────────────
# Supabase Storage
# ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_URL=
SUPABASE_MAX_IMAGE_SIZE=5120
SUPABASE_MAX_DOCUMENT_SIZE=10240

VITE_APP_NAME="${APP_NAME}"

# ──────────────────────────────────────────────
# Frontend API URL (for Vercel builds)
# In production: https://your-app.onrender.com/api
# ──────────────────────────────────────────────
VITE_API_URL=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173,localhost:8000

PLATFORM_ADMIN_LOGIN_PATH=platform-secure-admin-login
